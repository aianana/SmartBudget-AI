generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Таблица пользователей
model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String
  filesUsed     Int           @default(0)   
  questionsUsed Int           @default(0)   
  statsJson     String?       
  
  transactions  Transaction[]
  advices       Advice[]
  histories     History[]     
}

// История вопросов и ответов
model History {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  createdAt DateTime @default(now())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

// Таблица транзакций 
model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Float    
  date        DateTime 
  category    String   
  description String?  
  
  userId      Int      
  user        User     @relation(fields: [userId], references: [id])
}

// Таблица советов от AI
model Advice {
  id        Int      @id @default(autoincrement())
  message   String   
  createdAt DateTime @default(now()) 
  
  userId    Int      
  user      User     @relation(fields: [userId], references: [id])
}